# ============================================================
# TalentRadar — Environment Variables
# Copy this file to .env and fill in your actual values
# ============================================================

# ─── Gemini API ─────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── HydraDB ────────────────────────────────────────────────
# PostgreSQL connection string for your HydraDB instance
# Format: postgresql://user:password@host:port/dbname
HYDRADB_CONNECTION_STRING=postgresql://YOUR_USER:YOUR_PASSWORD@YOUR_HOST:5432/YOUR_DB_NAME

# ─── GitHub API (Optional, increases rate limit) ────────────
# Get from: https://github.com/settings/tokens (no scopes needed)
GITHUB_TOKEN=YOUR_GITHUB_TOKEN_HERE

# ─── Backend Config ─────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173

# ─── Mode ───────────────────────────────────────────────────
# Set to "true" to use in-memory mock data (no HydraDB needed)
MOCK_MODE=true
